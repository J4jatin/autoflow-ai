# AutoFlow AI — Environment Variables
# Copy this file to .env and fill in values as needed.
# The app works without any of these set (uses defaults).

# API settings
APP_ENV=development
LOG_LEVEL=INFO

# LocalStack endpoint (used by AWS CLI / CDK during local deploy)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=eu-central-1
